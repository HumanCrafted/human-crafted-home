{% comment %} Footer social links — collapsed behind a "socials" disclosure {% endcomment %}
<details class="footer-socials">
  <summary>socials</summary>
  <span class="social-links-list">
    {% for social in site.data.social %}
        {% if social.enabled %}
            {% assign social_label = social.name | downcase %}
            {% if social_label == "x-twitter" %}{% assign social_label = "twitter" %}{% endif %}
            <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" data-umami-event="Social click" data-umami-event-platform="{{ social.name }}">{{ social_label }}</a>
        {% endif %}
    {% endfor %}
  </span>
</details>
